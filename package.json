{
  "name": "solid-web-components",
  "version": "2.0.0",
  "description": "Web components for querying, including, and editing RDF/Linked Data",
  "type": "module",
  "main": "sol-query.js",
  "exports": {
    ".": "./sol-query.js",
    "./rdf": "./shared/rdf-utils.js",
    "./ui": "./utils/sol-query-ui.js",
    "./triple-patterns": "./utils/sol-query-triple-patterns.js",
    "./include": "./sol-include.js",
    "./live-edit": "./sol-live-edit.js",
    "./login": "./sol-login.js",
    "./modal": "./sol-modal.js",
    "./pod": "./sol-pod.js",
    "./pod-ops": "./sol-pod-ops.js",
    "./pod-utils": "./shared/pod-ops.js",
    "./accordion": "./sol-accordion.js",
    "./rolodex": "./sol-rolodex.js",
    "./tabs": "./sol-tabs.js",
    "./menu": "./sol-menu.js",
    "./wac": "./sol-wac.js",
    "./solidos": "./sol-solidos.js",
    "./node": "./sol-query-node.js",
    "./login-node": "./sol-login-node.js",
    "./bundle": "./solid-web-components.bundle.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/.bin/jest",
    "bundle": "rollup -c rollup.config.js --environment MINIFY:true",
    "bundle:all": "rollup -c rollup.config.js --environment MINIFY:true",
    "lint": "eslint .",
    "docs": "jsdoc -c jsdoc.config.json"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@eslint/js": "^8.57.1",
    "@rdfjs/dataset": "^2.0.2",
    "@rdfjs/namespace": "^2.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-jest": "^29.7.0",
    "clownface": "^2.0.3",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdoc": "^4.0.5",
    "n3": "^2.0.3",
    "rdf-ext": "^2.6.0",
    "rdf-validate-shacl": "^0.6.5",
    "rollup": "^4.13.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(your-esm-pkg)/)"
    ],
    "moduleNameMapper": {
      "^rdflib$": "<rootDir>/tests/__mocks__/rdflib-esm.js",
      "^https://esm\\.sh/rdflib@2$": "<rootDir>/tests/__mocks__/rdflib-esm.js",
      "^@inrupt/solid-client-authn-node$": "<rootDir>/tests/__mocks__/solid-client-authn-node.js",
      "^openid-client$": "<rootDir>/tests/__mocks__/openid-client.js",
      "^dompurify$": "<rootDir>/tests/__mocks__/dompurify.js",
      "^marked$": "<rootDir>/tests/__mocks__/marked.js"
    },
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "@comunica/query-sparql": "^5.1.3",
    "@inrupt/solid-client-authn-browser": "^4.0.0",
    "dompurify": "^3.4.0",
    "marked": "^18.0.0",
    "rdflib": "^2.3.6"
  }
}
