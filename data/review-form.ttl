@prefix ui: <http://www.w3.org/ns/ui#> .
@prefix ex: <http://example.org/> .

ex:contactForm a ui:Form ;
  ui:title "Contact Us" ;
  ui:description "Please fill out this form to get in touch with us." ;
  ui:parts (
    ex:nameField
    ex:emailField
    ex:subjectField
    ex:messageField
  ) .

ex:nameField a ui:SingleLineTextField ;
  ui:label "Full Name" ;
  ui:required true ;
  ui:help "Your full name" .

ex:emailField a ui:EmailField ;
  ui:label "Email Address" ;
  ui:required true ;
  ui:help "We'll use this to respond to you" .

ex:subjectField a ui:SingleLineTextField ;
  ui:label "Subject" ;
  ui:required true .

ex:messageField a ui:TextArea ;
  ui:label "Message" ;
  ui:required true ;
  ui:help "Tell us what you'd like to say" .
